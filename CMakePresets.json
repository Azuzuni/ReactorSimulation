{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "raylib-entt",
      "inherits": "base",
      "cacheVariables": {
        "RENDERING": "raylib",
        "ECS": "entt"
      }
    },
    {
      "name": "sfml-entt",
      "inherits": "base",
      "cacheVariables": {
        "RENDERING": "sfml",
        "ECS": "entt"
      }
    }
  ]
}
